# Storage mode: "local" (default, indexedDB) or "server" (SQLite)
PUBLIC_STORAGE_MODE=local

# SQLite database file path (server mode only)
DB_PATH=data/erdmini.db

# Auth settings (server mode only)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme
SESSION_MAX_AGE_DAYS=30
PUBLIC_APP_URL=http://localhost:5173

# SEO: canonical site URL (used for og:url, sitemap, etc.)
PUBLIC_SITE_URL=https://erdmini.dornol.dev
