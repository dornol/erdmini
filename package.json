{
	"name": "erdmini",
	"private": true,
	"version": "0.9.6",
	"license": "MIT",
	"type": "module",
	"packageManager": "pnpm@10.30.1",
	"scripts": {
		"dev": "vite dev --host",
		"dev:server": "cross-env PUBLIC_STORAGE_MODE=server vite dev --host",
		"build": "cross-env PUBLIC_STORAGE_MODE=local vite build && cp build/404.html build/index.html",
		"build:server": "cross-env PUBLIC_STORAGE_MODE=server vite build",
		"start:server": "node server.js",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"test": "vitest run",
		"test:watch": "vitest"
	},
	"devDependencies": {
		"@inlang/paraglide-js": "^2.16.0",
		"@sveltejs/adapter-auto": "^7.0.0",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.57.1",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/vite": "^4.2.4",
		"@types/better-sqlite3": "^7.6.13",
		"@types/d3-force": "^3.0.10",
		"@types/ws": "^8.18.1",
		"cross-env": "^10.1.0",
		"happy-dom": "^20.9.0",
		"playwright": "^1.59.1",
		"svelte": "^5.55.4",
		"svelte-check": "^4.4.6",
		"tailwindcss": "^4.2.4",
		"typescript": "^6.0.3",
		"vite": "^7.3.1",
		"vitest": "^4.1.5"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"better-sqlite3"
		]
	},
	"dependencies": {
		"@codemirror/commands": "^6.10.3",
		"@codemirror/lang-sql": "^6.10.0",
		"@codemirror/state": "^6.6.0",
		"@codemirror/theme-one-dark": "^6.1.3",
		"@codemirror/view": "^6.41.1",
		"@loancrate/prisma-schema-parser": "^3.0.0",
		"@modelcontextprotocol/sdk": "^1.29.0",
		"@node-rs/argon2": "^2.0.2",
		"@sveltejs/adapter-node": "^5.5.4",
		"better-sqlite3": "^12.9.0",
		"codemirror": "^6.0.2",
		"d3-force": "^3.0.0",
		"html-to-image": "^1.11.13",
		"jspdf": "^4.2.1",
		"ldapts": "^8.1.7",
		"node-sql-parser": "^5.4.0",
		"openid-client": "^6.8.4",
		"sql.js": "^1.14.1",
		"svg2pdf.js": "^2.7.0",
		"ws": "^8.20.0",
		"xlsx": "^0.18.5",
		"zod": "^4.4.3"
	}
}
